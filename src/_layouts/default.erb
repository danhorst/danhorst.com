<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="x-ua-compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="theme-color" content="#fffff8" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#000000" media="(prefers-color-scheme: dark)" />
    <meta name="color-scheme" content="light dark" />
    <meta name="darkreader-lock" />

    <% if slotted?(:page_title) %>
    <title><%= slotted(:page_title) %></title>
    <% elsif page.data.title %>
    <title><%= page.data.title %> | <%= site.metadata.title %></title>
    <% else %>
    <title><%= site.metadata.title %></title>
    <% end %>

    <% if page.data.description %>
    <meta name="description" content="<%= page.data.description %>" />
    <% end %>
    <meta name="author" content="<%= site.metadata.author %>" />

    <%= slotted :head_extra %>

    <link rel="alternate" type="application/rss+xml" href="<%= site.config.url %>/feed" title="<%= site.metadata.title %>" />
    <link rel="me" href="https://ruby.social/@danhorst" />
    <link rel="preload" as="font" type="font/woff2" href="/font/et-book-ot-roman.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2" href="/font/et-book-ot-italic.woff2" crossorigin />
    <link rel="stylesheet" href="/css/main.css" />
    <link rel="stylesheet" href="/css/baguetteBox.min.css" />
    <link rel="apple-touch-icon" href="/img/icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <% if page.relative_url.to_s.start_with?("/rum") %>
    <link rel="icon" type="image/png" sizes="32x32" href="/img/rum-guide-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/img/rum-guide-16x16.png" />
    <link rel="shortcut icon" type="image/x-icon" href="/img/rum-guide.ico" />
    <link rel="icon" type="image/x-icon" href="/img/rum-guide.ico" />
    <% else %>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <% end %>

    <script src="/js/turbolinks.js" defer></script>
    <script src="/js/baguetteBox.min.js" defer></script>
    <script>
      document.addEventListener("turbolinks:load", function() {
        document.querySelectorAll("main.interactive input[disabled]").forEach(function(item, i){item.removeAttribute("disabled")});
        baguetteBox.run('.lightbox');
      });
    </script>
  </head>
  <body>
    <header role="banner">
      <% url = page.relative_url.to_s %>
      <% if url.start_with?("/rum") %>
      <nav role="navigation">
        <span><a href="/">Dan Brubaker Horst</a></span>
        <ul>
          <li><a href="/rum/">Dan's Rum Guide</a></li>
        </ul>
      </nav>
      <% else %>
      <nav role="navigation">
        <span><% if url == "/" %>Dan Brubaker Horst<% else %><a href="/">Dan Brubaker Horst</a><% end %></span>
        <ul>
          <% if url.start_with?("/food") %><li>Food</li><% end %>
          <li><% if url.start_with?("/writing") %>Writing<% else %><a href="/writing/">Writing</a><% end %></li>
          <li><% if url.start_with?("/lists") %>Lists<% else %><a href="/lists/">Lists</a><% end %></li>
          <li><% if url.start_with?("/about") %>About<% else %><a href="/about/">About</a><% end %></li>
        </ul>
      </nav>
      <% end %>
    </header>
    <main role="main"<% if page.data.tags&.include?("interactive") %> class="interactive"<% end %>>
      <%= slotted :heading %>
      <%= yield %>
    </main>
    <%= slotted :page_footer %>
  </body>
</html>
