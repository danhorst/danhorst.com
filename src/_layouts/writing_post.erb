---
layout: default
---
<% slot :head_extra, transform: false do -%>
<meta name="fediverse:creator" content="@danhorst@ruby.social">
<% end -%>

<% if page.data.categories&.include?("Archived") -%>
<% slot :heading, transform: false do -%>
<article class="archived-post">
  <section>
    <p><em>
      I wrote this when I was the Digital Library Applications Lead at the University of Notre Dame.
      It was archived from http://www3.nd.edu/~dbrubak1/ which no longer exists.
    </em></p>
  </section>
</article>
<% end -%>
<% end -%>

<article>
  <header>
    <h1><%= page.data.title %></h1>
    <p class="post-meta">
      <time datetime="<%= page.data.date&.strftime("%Y-%m-%dT%H:%M:%S%:z") %>"><%= page.data.date&.strftime("%A %B %-d, %Y") %></time>
      by <%= page.data.author || site.metadata.author %>
      <% if page.data.categories&.any? || page.data.tags&.any? %>
        in <%= render "meta_terms", page: page %>
      <% end %>
    </p>
  </header>

  <section>
    <%= yield %>
  </section>
</article>
