#!/usr/bin/env ruby
# frozen_string_literal: true

require "html-proofer"

output_dir = File.expand_path("../output", __dir__)

unless Dir.exist?(output_dir)
  warn "No output/ directory found. Run `bin/bridgetown build` first."
  exit 1
end

options = {
  ignore_urls: [/localhost/],  # dev-build artifacts (e.g. RSS feed href)
  enforce_https: false,        # local builds use http://localhost
  disable_external: true,
  checks: %w[Links Images],
}

puts "Checking internal links…"
puts "(For external links run bin/check-external-links)\n\n"

HTMLProofer.check_directory(output_dir, options).run
